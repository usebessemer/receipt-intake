# receipt-intake — config. Copy to .env and fill. NEVER commit .env.

# --- Intake email (SWAPPABLE) ---
# The inbox the service polls for receipt emails. A config change, not a code change.
GMAIL_INTAKE_ADDRESS=receipts.example@gmail.com
GMAIL_OAUTH_CLIENT_PATH=./secrets/gmail_oauth_client.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
GMAIL_PROCESSED_LABEL=processed

# --- Anthropic (extraction) ---
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTION_MODEL=claude-haiku-4-5-20251001

# --- Service (entrypoint) ---
# Seconds between polls in loop mode (`python main.py loop`).
POLL_INTERVAL_SECONDS=300

# --- Notifications ---
# Address for review-queue notifications (optional; unused in v1).
NOTIFY_EMAIL=

# Sink/resolver adapters own their own settings — configure your target-system
# adapter where you wire it in main.py (see README "Wiring a real sink").
